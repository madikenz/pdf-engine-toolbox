# PDF Engine Toolbox - Environment Variables
# Copy to .env and fill in values

# Shared HMAC secret for authenticating API requests
# Must match the secret configured in your calling application
PDF_ENGINE_SECRET=change-me-to-a-64-char-random-hex-string

# Logging level: debug, info, warning, error
LOG_LEVEL=info

# Maximum PDF file size in MB
MAX_UPLOAD_SIZE_MB=100

# Uvicorn worker count
WORKERS=2

# Request timeout in seconds
REQUEST_TIMEOUT_SECONDS=120

# Cache settings
CACHE_ENABLED=true
CACHE_DIR=/tmp/pdf_engine_cache
CACHE_MAX_SIZE_MB=500
CACHE_TTL_SECONDS=3600
